apiVersion: v1
kind: Secret
metadata:
  name: fastpass-secrets
  namespace: default
type: Opaque
stringData:
  # PostgreSQL connection string
  # Format: host=<hostname> user=<username> password=<password> dbname=<database> port=5432 sslmode=disable
  database-url: "host=postgres-service user=postgres password=CHANGE_ME dbname=fastpass port=5432 sslmode=disable"
  
  # JWT secret for signing tokens (generate with: openssl rand -base64 32)
  jwt-secret: "CHANGE_ME_TO_RANDOM_SECRET"
