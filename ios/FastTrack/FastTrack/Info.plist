<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">

<dict>
    <!-- Photo library access for profile picture upload -->
    <key>NSPhotoLibraryUsageDescription</key>
    <string>FastTrack accesses your photo library so you can set a profile picture.</string>

    <!-- Location permission descriptions -->
    <key>NSLocationWhenInUseUsageDescription</key>
    <string>FastTrack needs your location to track your speed and route during drives.</string>

    <key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
    <string>FastTrack needs background location access to continue tracking your drives even when the app is in the background.</string>

    <key>NSLocationAlwaysUsageDescription</key>
    <string>FastTrack tracks your drives in the background to provide accurate statistics.</string>
    
    <!-- Motion permission for accelerometer/gyroscope sensor fusion -->
    <key>NSMotionUsageDescription</key>
    <string>FastTrack uses motion data to improve speed accuracy by combining GPS with accelerometer data.</string>
    
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
	</array>

	<!-- OAuth 2.0 callback URL scheme -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.toper.fasttrack.oauth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.toper.fasttrack</string>
			</array>
		</dict>
	</array>

	<!-- Export compliance: app uses HTTPS only, no custom encryption -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>

	<!-- Live Activities (also displays on CarPlay Dashboard, iOS 17+) -->
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>NSSupportsLiveActivitiesFrequentUpdates</key>
	<true/>

	<!-- Required hardware capabilities -->
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>gps</string>
		<string>location-services</string>
	</array>
</dict>
</plist>
